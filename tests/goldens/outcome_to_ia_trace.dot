digraph ia_place_map {
  rankdir=LR;
  graph [dpi=192, fontname="Public Sans"];
  node [shape=box, fontname="Public Sans"];
  edge [fontname="Public Sans"];
  subgraph cluster_A_001 {
    label="Checkout Area";
    "P-001" [label="Billing\n/checkout/billing\n[auth]"];
    "P-002" [label="Review\n/checkout/review\n[auth]"];
  }
  "P-001" -> "P-002" [style=invis, weight=100];
  "P-001" -> "P-002";
}
