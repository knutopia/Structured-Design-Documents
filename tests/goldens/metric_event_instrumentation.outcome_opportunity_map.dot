digraph outcome_opportunity_map {
  rankdir=LR;
  graph [fontname="Public Sans", nodesep=0.6, ranksep=1.0];
  node [fontname="Public Sans"];
  edge [fontname="Public Sans"];
  subgraph rank_initiative {
    rank=same;
    "lane_initiative" [shape=plaintext, label="Initiatives"];
    "I-050" [shape=box, label="Review Queue Instrumentation"];
  }
  subgraph rank_opportunity {
    rank=same;
    "lane_opportunity" [shape=plaintext, label="Opportunities"];
    "OP-050" [shape=hexagon, label="Review Queue Visibility"];
  }
  subgraph rank_outcome {
    rank=same;
    "lane_outcome" [shape=plaintext, label="Outcomes"];
    "O-050" [shape=ellipse, label="Reduce Risk Review Delays"];
  }
  subgraph rank_metric {
    rank=same;
    "lane_metric" [shape=plaintext, label="Metrics"];
    "M-050" [shape=note, label="Alert Stream Coverage\nEvent: E-050 Alert Emitted\nEvent: E-051 Review Completed Event"];
    "M-051" [shape=note, label="Manual Review Completion\nExperience: J-050 Review Risk Alert\nEvent: E-051 Review Completed Event"];
  }
  "lane_initiative" -> "lane_opportunity" [style=invis, weight=100];
  "lane_opportunity" -> "lane_outcome" [style=invis, weight=100];
  "lane_outcome" -> "lane_metric" [style=invis, weight=100];
  "lane_initiative" -> "I-050" [style=invis, weight=100];
  "lane_opportunity" -> "OP-050" [style=invis, weight=100];
  "lane_outcome" -> "O-050" [style=invis, weight=100];
  "lane_metric" -> "M-050" [style=invis, weight=100];
  "M-050" -> "M-051" [style=invis, weight=100];
  "I-050" -> "OP-050" [label="addresses"];
  "O-050" -> "M-050" [label="measured by"];
  "O-050" -> "M-051" [label="measured by"];
  "OP-050" -> "O-050" [label="supports"];
}