digraph ia_place_map {
  rankdir=LR;
  graph [fontname="Public Sans"];
  node [shape=box, fontname="Public Sans"];
  edge [fontname="Public Sans"];
  "P-700" [label="Dashboard"];
  "P-900" [label="Reports"];
  subgraph cluster_A_200 {
    label="Workflows";
    "P-300" [label="Zeta"];
    "P-100" [label="Alpha"];
    "P-200" [label="Beta"];
  }
  subgraph cluster_A_500 {
    label="Archive";
    "P-050" [label="Archive Home"];
  }
  "P-700" -> "P-300" [style=invis, weight=100];
  "P-300" -> "P-050" [style=invis, weight=100];
  "P-300" -> "P-100" [style=invis, weight=100];
  "P-100" -> "P-200" [style=invis, weight=100];
  "P-700" -> "P-900";
}
