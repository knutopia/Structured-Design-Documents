digraph ui_contracts {
  rankdir=LR;
  graph [fontname="Public Sans", compound=true, nodesep=0.7, ranksep=1.0];
  node [fontname="Public Sans"];
  edge [fontname="Public Sans"];
  subgraph cluster_P_100 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Dashboard</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-100__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    "C-900" [shape="box", style="rounded", label="Global Navigation"];
  }
  subgraph cluster_P_110 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Report View</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-110__anchor" [label="", shape="point", width=0, height=0, style="invis"];
  }
  subgraph cluster_P_210 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Projections Overview</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-210__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    "VS-210a" [shape="box", style="rounded,dashed", label="Projection List"];
    "VS-210b" [shape="box", style="rounded,dashed", label="Duplicate Projection Dialog"];
    "VS-210c" [shape="box", style="rounded,dashed", label="Delete Projection Confirmation Dialog"];
    "VS-210d" [shape="box", style="rounded,dashed", label="Add Projection to Dashboard Confirmation Dialog"];
    "C-900" [shape="box", style="rounded", label="Global Navigation"];
  }
  subgraph cluster_P_220 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Projection</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-220__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    "VS-220a" [shape="box", style="rounded,dashed", label="Overview Tab"];
    "VS-220b" [shape="box", style="rounded,dashed", label="Fee Schedules Tab"];
    "VS-220c" [shape="box", style="rounded,dashed", label="Funds Tab"];
  }
  subgraph cluster_P_221 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Fee Schedule Scenario Details</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-221__anchor" [label="", shape="point", width=0, height=0, style="invis"];
  }
  subgraph cluster_P_222 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Funding Scenario Details</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-222__anchor" [label="", shape="point", width=0, height=0, style="invis"];
  }
  subgraph cluster_P_230 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Create New Projection</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-230__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    "VS-230a" [shape="box", style="rounded,dashed", label="Create New Projection Step 1"];
    "VS-230b" [shape="box", style="rounded,dashed", label="Create New Projection Step 2"];
    "VS-230c" [shape="box", style="rounded,dashed", label="Create New Projection Step 3"];
  }
  subgraph cluster_P_310 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Current Bills</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-310__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    "C-900" [shape="box", style="rounded", label="Global Navigation"];
  }
  subgraph cluster_P_410 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Review Past Bills</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-410__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    "C-900" [shape="box", style="rounded", label="Global Navigation"];
  }
  subgraph cluster_P_510 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Manage Accounts</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-510__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    "C-900" [shape="box", style="rounded", label="Global Navigation"];
  }
  subgraph cluster_P_610 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Manage Fee Schedules</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-610__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    "C-900" [shape="box", style="rounded", label="Global Navigation"];
  }
  "P-100__anchor" -> "P-110__anchor" [style=invis, weight=100];
  "P-110__anchor" -> "P-210__anchor" [style=invis, weight=100];
  "P-210__anchor" -> "P-220__anchor" [style=invis, weight=100];
  "P-220__anchor" -> "P-221__anchor" [style=invis, weight=100];
  "P-221__anchor" -> "P-222__anchor" [style=invis, weight=100];
  "P-222__anchor" -> "P-230__anchor" [style=invis, weight=100];
  "P-230__anchor" -> "P-310__anchor" [style=invis, weight=100];
  "P-310__anchor" -> "P-410__anchor" [style=invis, weight=100];
  "P-410__anchor" -> "P-510__anchor" [style=invis, weight=100];
  "P-510__anchor" -> "P-610__anchor" [style=invis, weight=100];
  "P-100__anchor" -> "C-900" [style=invis, weight=100];
  "P-210__anchor" -> "VS-210a" [style=invis, weight=100];
  "VS-210a" -> "VS-210b" [style=invis, weight=100];
  "VS-210b" -> "VS-210c" [style=invis, weight=100];
  "VS-210c" -> "VS-210d" [style=invis, weight=100];
  "VS-210d" -> "C-900" [style=invis, weight=100];
  "P-220__anchor" -> "VS-220a" [style=invis, weight=100];
  "VS-220a" -> "VS-220b" [style=invis, weight=100];
  "VS-220b" -> "VS-220c" [style=invis, weight=100];
  "P-230__anchor" -> "VS-230a" [style=invis, weight=100];
  "P-310__anchor" -> "C-900" [style=invis, weight=100];
  "P-410__anchor" -> "C-900" [style=invis, weight=100];
  "P-510__anchor" -> "C-900" [style=invis, weight=100];
  "P-610__anchor" -> "C-900" [style=invis, weight=100];
  "VS-230a" -> "VS-230b" [style="solid", weight=4];
  "VS-230b" -> "VS-230c" [style="solid", weight=4];
}