{
  "name": "sdd-toolchain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.31.0",
  "bin": {
    "sdd": "./dist/cli/main.js",
    "sdd-helper": "./dist/cli/helperMain.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm run build && vitest run",
    "check": "pnpm run test",
    "check:graphviz": "node ./scripts/check-graphviz.mjs",
    "generate:rendered-examples": "TMPDIR=/tmp pnpm run build && node dist/examples/generateRenderedExamples.js",
    "sdd": "node dist/cli/main.js",
    "sdd-helper": "node dist/cli/helperMain.js"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "ajv": "^8.17.1",
    "commander": "^12.1.0",
    "elkjs": "^0.11.1",
    "fontkit": "^2.0.4",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
