                  "endColumn": {
                    "type": "number"
                  },
                  "startOffset": {
                    "type": "number"
                  },
                  "endOffset": {
                    "type": "number"
                  }
                },
                "additionalProperties": false,
                "required": [
                  "line",
                  "column",
                  "endLine",
                  "endColumn",
                  "startOffset",
                  "endOffset"
                ]
              },
              "ruleId": {
                "type": "string"
              },
              "profileId": {
                "type": "string"
              },
              "relatedIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "stage",
              "code",
              "severity",
              "message",
              "file"
            ]
          }
