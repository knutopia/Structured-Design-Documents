                  "error",
                  "warn",
                  "info"
                ]
              },
              "message": {
                "type": "string"
              },
              "file": {
                "type": "string"
              },
              "span": {
                "type": "object",
                "properties": {
                  "line": {
                    "type": "number"
                  },
                  "column": {
                    "type": "number"
                  },
                  "endLine": {
                    "type": "number"
