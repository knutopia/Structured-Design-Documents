digraph ui_contracts {
  rankdir=LR;
  graph [fontname="Public Sans", compound=true, nodesep=0.7, ranksep=1.0];
  node [fontname="Public Sans"];
  edge [fontname="Public Sans"];
  subgraph cluster_P_010 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Billing</TD></TR><TR><TD ALIGN="LEFT">/billing</TD></TR><TR><TD ALIGN="LEFT">[auth]</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-010__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    subgraph cluster_VS_010a {
      graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">ViewState: Billing Editing</TD></TR><TR><TD ALIGN="LEFT">data: PaymentMethod</TD></TR></TABLE>>, style="rounded,dashed", labelloc="t", labeljust="l"];
      subgraph cluster_C_011 {
        graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Component: Submit Button</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
        "C-011__body" [shape="plaintext", label="", width=0.01, height=0.01];
      }
      "C-011__anchor" [label="", shape="point", width=0.08, height=0.08, style="filled", color="#666666", fillcolor="#666666"];
      "E-010" [shape="oval", label="Submit"];
      "C-011__anchor" -> "E-010" [label="emits", style="dashed", constraint=true];
    }
    "VS-010a__anchor" [label="", shape="point", width=0.08, height=0.08, style="filled", color="#666666", fillcolor="#666666"];
    "VS-010b" [shape="box", style="rounded,dashed", label="Billing Success\ndata: Receipt"];
    subgraph cluster_C_010 {
      graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Component: Billing Form</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
      subgraph cluster_secondary_state_group_C_010 {
        graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">State detail: Billing Form</TD></TR><TR><TD ALIGN="LEFT">scope_id=C-010</TD></TR></TABLE>>, style="rounded,dashed", labelloc="t", labeljust="l"];
        "secondary_state_group:C-010__anchor" [label="", shape="point", width=0, height=0, style="invis"];
        "ST-010a" [shape="ellipse", style="dashed", label="Form Ready"];
        "ST-010b" [shape="ellipse", style="dashed", label="Submitting"];
      }
    }
    "C-010__anchor" [label="", shape="point", width=0.08, height=0.08, style="filled", color="#666666", fillcolor="#666666"];
    "SA-010" [shape="component", label="Save Subscription"];
    "D-010" [shape="cylinder", label="Subscription"];
  }
  subgraph cluster_P_011 {
    graph [label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0"><TR><TD ALIGN="LEFT">Confirmation</TD></TR><TR><TD ALIGN="LEFT">/confirmation</TD></TR><TR><TD ALIGN="LEFT">[role:billing_agent]</TD></TR></TABLE>>, style="rounded", labelloc="t", labeljust="l"];
    "P-011__anchor" [label="", shape="point", width=0, height=0, style="invis"];
  }
  "P-010__anchor" -> "P-011__anchor" [style=invis, weight=100];
  "C-010__anchor" -> "D-010" [label="binds field status", style="dotted", constraint=true];
  "C-010__anchor" -> "SA-010" [label="depends on", constraint=true];
  "ST-010a" -> "ST-010b" [label="[Submit] {payment_valid} / SA-010", style="dashed", weight=3];
  "VS-010a__anchor" -> "VS-010b" [label="[Submit] {payment_valid} / SA-010", style="solid", weight=4];
}
