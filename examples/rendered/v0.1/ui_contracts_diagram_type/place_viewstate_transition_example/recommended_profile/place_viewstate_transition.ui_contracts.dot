digraph ui_contracts {
  rankdir=LR;
  graph [fontname="Public Sans", compound=true, nodesep=0.7, ranksep=1.0];
  node [fontname="Public Sans"];
  edge [fontname="Public Sans"];
  subgraph cluster_P_010 {
    graph [label="", style="rounded"];
    "P-010__title" [shape="plaintext", label="Billing\l/billing\l[auth]\l"];
    subgraph cluster_VS_010a {
      graph [label="", style="rounded,dashed"];
      "VS-010a__title" [shape="plaintext", label="ViewState: Billing Editing\ldata: PaymentMethod\l"];
      subgraph cluster_C_011 {
        graph [label="", style="rounded"];
        "C-011__title" [shape="plaintext", label="Component: Submit Button\l"];
        "E-010" [shape="oval", label="Submit"];
      }
    }
    "VS-010b" [shape="box", style="rounded,dashed", label="Billing Success\ndata: Receipt"];
    subgraph cluster_C_010 {
      graph [label="", style="rounded"];
      "C-010__title" [shape="plaintext", label="Component: Billing Form\l"];
      "SA-010" [shape="component", label="Save Subscription"];
      "D-010" [shape="cylinder", label="Subscription"];
      subgraph cluster_secondary_state_group_C_010 {
        graph [label="", style="rounded,dashed"];
        "secondary_state_group:C-010__title" [shape="plaintext", label="State detail: Billing Form\lscope_id=C-010\l"];
        "ST-010a" [shape="ellipse", style="dashed", label="Form Ready"];
        "ST-010b" [shape="ellipse", style="dashed", label="Submitting"];
      }
    }
  }
  subgraph cluster_P_011 {
    graph [label="", style="rounded"];
    "P-011__title" [shape="plaintext", label="Confirmation\l/confirmation\l[role:billing_agent]\l"];
  }
  "P-010__title" -> "P-011__title" [style=invis, weight=100];
  "P-010__title" -> "VS-010a__title" [style=invis, weight=100];
  "VS-010b" -> "C-010__title" [style=invis, weight=100];
  "VS-010a__title" -> "C-011__title" [style=invis, weight=100];
  "D-010" -> "secondary_state_group:C-010__title" [style=invis, weight=100];
  "secondary_state_group:C-010__title" -> "ST-010a" [style=invis, weight=100];
  "C-010__title" -> "D-010" [label="binds field status", style="dotted", constraint=true];
  "C-010__title" -> "SA-010" [label="depends on", constraint=true];
  "C-011__title" -> "E-010" [label="emits", style="dashed", constraint=true];
  "ST-010a" -> "ST-010b" [label="[Submit] {payment_valid} / SA-010", style="dashed", weight=3];
  "VS-010a__title" -> "VS-010b" [label="[Submit] {payment_valid} / SA-010", style="solid", weight=4];
}
