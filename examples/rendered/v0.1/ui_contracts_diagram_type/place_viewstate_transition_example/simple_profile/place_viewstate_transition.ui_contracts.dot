digraph ui_contracts {
  rankdir=LR;
  graph [fontname="Public Sans", compound=true, nodesep=0.7, ranksep=1.0];
  node [fontname="Public Sans"];
  edge [fontname="Public Sans"];
  subgraph cluster_P_010 {
    graph [label="", style="rounded"];
    "P-010__title" [shape="plaintext", label="Billing\l"];
    subgraph cluster_VS_010a {
      graph [label="", style="rounded,dashed"];
      "VS-010a__title" [shape="plaintext", label="ViewState: Billing Editing\l"];
      "C-011" [shape="box", style="rounded", label="Submit Button"];
    }
    "VS-010b" [shape="box", style="rounded,dashed", label="Billing Success"];
    "C-010" [shape="box", style="rounded", label="Billing Form"];
  }
  subgraph cluster_P_011 {
    graph [label="", style="rounded"];
    "P-011__title" [shape="plaintext", label="Confirmation\l"];
  }
  "P-010__title" -> "P-011__title" [style=invis, weight=100];
  "P-010__title" -> "VS-010a__title" [style=invis, weight=100];
  "VS-010b" -> "C-010" [style=invis, weight=100];
  "VS-010a__title" -> "C-011" [style=invis, weight=100];
  "VS-010a__title" -> "VS-010b" [label="[Submit] {payment_valid} / SA-010", style="solid", weight=4];
}
