digraph ui_contracts {
  rankdir=LR;
  graph [fontname="Public Sans", compound=true, nodesep=0.7, ranksep=1.0];
  node [fontname="Public Sans"];
  edge [fontname="Public Sans"];
  subgraph cluster_P_060 {
    graph [label="Case Review", style="rounded"];
    "P-060__anchor" [label="", shape="point", width=0, height=0, style="invis"];
    subgraph cluster_secondary_state_group_P_060 {
      graph [label="State graph: Case Review\nscope_id=P-060", style="rounded"];
      "ST-060a" [shape="ellipse", label="Case Review Ready"];
      "ST-060b" [shape="ellipse", label="Case Review Submitted"];
    }
    subgraph cluster_C_060 {
      graph [label="Component: Review Panel", style="rounded"];
      "C-060__anchor" [label="", shape="point", width=0, height=0, style="invis"];
      "E-060" [shape="oval", label="Submit Review"];
      "SA-060" [shape="component", label="Save Review"];
      "D-060" [shape="cylinder", label="CaseRecord"];
      subgraph cluster_secondary_state_group_C_060 {
        graph [label="State graph: Review Panel\nscope_id=C-060", style="rounded"];
        "ST-061a" [shape="ellipse", label="Panel Idle"];
        "ST-061b" [shape="ellipse", label="Panel Dirty"];
      }
    }
  }
  "P-060__anchor" -> "ST-060a" [style=invis, weight=100];
  "ST-060a" -> "C-060__anchor" [style=invis, weight=100];
  "D-060" -> "ST-061a" [style=invis, weight=100];
  "C-060__anchor" -> "D-060" [label="binds field status", style="dotted", constraint=true];
  "C-060__anchor" -> "SA-060" [label="depends on", constraint=true];
  "C-060__anchor" -> "E-060" [label="emits", style="dashed", constraint=true];
  "ST-060a" -> "ST-060b" [label="[Submit Review] / SA-060", style="solid", weight=4];
  "ST-061a" -> "ST-061b" [label="[Submit Review] {draft_ready}", style="solid", weight=4];
}
